{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@microservices/source"],
	"baseUrl": ".",
    "paths": {
      "@source/utils": ["libs/shared/utils/index.ts"],
      "@source/types": ["libs/shared/types/index.ts"],
      "@source/tables": ["libs/shared/db/src/index.ts"],
      "@source/events": ["libs/events/index.ts"],
    }
  }
}
