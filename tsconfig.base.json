{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@microservices/source"],
	"baseUrl": ".",
    "paths": {
      "@source/types": ["libs/types/index.ts"],
      "db": ["libs/shared/db/src/index.ts"],
	  "@source/tables": ["libs/shared/db/src/index.ts"],
      "@source/events": ["libs/events/index.ts"],
      "@source/inngest": ["libs/inngest/src/client.ts"]
    }
  }
}
